# Copy to .env and fill in. NEVER commit .env

# MinIO (local data lake)
MINIO_ROOT_USER=resqadmin
MINIO_ROOT_PASSWORD=resqstats123
MINIO_ENDPOINT=http://localhost:9000

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=emergency_events

# Groq (free LLM for call classification) - https://console.groq.com
GROQ_API_KEY=

# Snowflake (Phase 5)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=RESQSTATS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Telegram alerts (Phase 6)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
